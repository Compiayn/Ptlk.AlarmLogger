@page "/recent-alarm-history"
@rendermode InteractiveServer
@using Microsoft.Extensions.Options
@using Ptlk.AlarmLogger.Configuration
@using Ptlk.AlarmLogger.Services.Status
@implements IDisposable
@inject AlarmHistoryQueryService Query
@inject IOptions<AlarmLoggerOptions> Options
@inject AlarmLoggerUiEventHub UiEvents

<div class="page-heading">
    <div>
        <h1>Recent Alarm History</h1>
        <span class="muted">Live updated: @FormatTimestamp(_lastRefreshedAt)</span>
    </div>
    <button class="btn primary" @onclick="LoadAsync">Refresh</button>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <p class="status danger">@_error</p>
}
else if (_result is null)
{
    <p class="status">Loading</p>
}
else if (_result.Data.Count == 0)
{
    <p class="status">No alarm history</p>
}
else
{
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>Source</th>
                    <th>Category</th>
                    <th>Condition</th>
                    <th>State</th>
                    <th>Quality</th>
                    <th>Ack</th>
                    <th>Message</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _result.Data)
                {
                    <tr>
                        <td>@FormatTimestamp(item.Timestamp)</td>
                        <td>@item.SourceName</td>
                        <td>@(item.CategoryTag ?? "-")</td>
                        <td>@item.ConditionName / @item.ConditionSubName</td>
                        <td><span class="@ActiveBadge(item.ConditionActive)">@ActiveText(item.ConditionActive)</span></td>
                        <td>@item.Quality</td>
                        <td>@AckText(item)</td>
                        <td class="clip">@item.Message</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private AlarmHistoryPageResult? _result;
    private string? _error;
    private DateTimeOffset? _lastRefreshedAt;
    private bool _disposed;
    private bool _loading;
    private bool _loadQueued;

    protected override async Task OnInitializedAsync()
    {
        UiEvents.HistoryChanged += HandleHistoryChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (_loading)
        {
            _loadQueued = true;
            return;
        }

        do
        {
            _loadQueued = false;
            _loading = true;
            try
            {
                await LoadOnceAsync();
            }
            catch
            {
                _error = "Failed to load recent alarm history.";
                _result = null;
                _lastRefreshedAt = DateTimeOffset.Now;
            }
            finally
            {
                _loading = false;
            }
        }
        while (_loadQueued && !_disposed);
    }

    private async Task LoadOnceAsync()
    {
        _error = null;
        var outcome = await Query.QueryPageAsync(0, Options.Value.RecentHistoryTake, "desc", null, null);
        if (outcome.Result is null)
        {
            _error = outcome.Error;
            _result = null;
        }
        else
        {
            _result = outcome.Result;
            _lastRefreshedAt = DateTimeOffset.Now;
        }
    }

    private void HandleHistoryChanged()
    {
        if (_disposed)
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            if (_disposed)
            {
                return;
            }

            await LoadAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        _disposed = true;
        UiEvents.HistoryChanged -= HandleHistoryChanged;
    }

    private static string AckText(AlarmHistoryItem item) =>
        item.NeedAck ? "Need Ack"
        : item.IsAcknowledge ? "Acknowledged"
        : "Clear";

    private static string ActiveText(bool value) => value ? "Active" : "Normal";

    private static string ActiveBadge(bool value) => value ? "badge badge-danger" : "badge badge-ok";

    private static string FormatTimestamp(DateTimeOffset? timestamp) =>
        timestamp?.ToString("yyyy-MM-dd HH:mm:ss zzz") ?? "-";
}
